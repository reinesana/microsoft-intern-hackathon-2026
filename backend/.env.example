# ---------- Azure AI Foundry ----------
# Endpoint from your Foundry project overview.
# Format: https://<resource>.services.ai.azure.com/api/projects/<project-name>
# Auth uses DefaultAzureCredential (run `az login` locally).
AZURE_AI_PROJECT_ENDPOINT=

# Model deployment name in Foundry (Models + endpoints page).
AZURE_AI_AGENT_MODEL=gpt-4o

# Stable agent name so we re-use the same agent across restarts.
AZURE_AI_AGENT_NAME=context-agent

# Bing grounding connection ID (Foundry portal → Connections).
BING_PROJECT_CONNECTION_ID=

# ---------- Azure AI Speech (Speech-to-Text) ----------
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
