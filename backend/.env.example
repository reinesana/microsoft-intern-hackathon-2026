# ---------- Azure AI Foundry ----------
# Project endpoint from your Foundry project Overview page, of the form:
#   https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_PROJECT_ENDPOINT=

# Model deployment name (the "Name" column under Models + endpoints), e.g. gpt-4o.
AZURE_AI_AGENT_MODEL=gpt-4o

# Stable agent name so we re-use the same agent across restarts.
AZURE_AI_AGENT_NAME=aegis-dispatch-agent

# Grounding with Bing Search connection ID. In your Foundry project, add a
# "Grounding with Bing Search" connection, then copy its connection ID here.
# The dispatch agent uses it to confirm dialect meanings it is unsure about.
BING_PROJECT_CONNECTION_ID=

# Transcription deployment for the audio path (main.py), e.g. whisper or
# gpt-4o-transcribe. Must be deployed in your Foundry project.
AZURE_AI_TRANSCRIBE_MODEL=whisper

# Auth is Entra ID via DefaultAzureCredential — run `az login` before starting.
# No API keys are needed anywhere.
